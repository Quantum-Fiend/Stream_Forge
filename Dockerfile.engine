FROM gradle:8-jdk17 AS build
WORKDIR /app
COPY . .
RUN ./gradlew :engine-scala:build -x test

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=build /app/engine-scala/build/libs/*.jar app.jar
ENV DATA_DIR=/data
ENV JAVA_OPTS="-Xmx4g -Xms1g -XX:+UseG1GC"
CMD ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
